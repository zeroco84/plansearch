# PlanSearch Environment Variables
# Copy this to .env and fill in values

# Database
DB_PASSWORD=plansearch_dev_password_change_me

# Master encryption key for API keys stored in DB (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
MASTER_ENCRYPTION_KEY=your-fernet-key-here

# Admin API bearer token (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
ADMIN_TOKEN=your-admin-token-here

# Claude API key and CRO API key are stored in the DATABASE
# encrypted with MASTER_ENCRYPTION_KEY — managed via admin UI
